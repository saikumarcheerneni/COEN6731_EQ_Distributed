FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY core/ ./core/
COPY prepare_data.py .

RUN mkdir -p checkpoints outputs data_shards

ENV PS_PORT=50051
ENV NUM_WORKERS=2
ENV LR=0.001
ENV STRAGGLER_TIMEOUT=30

EXPOSE 50051

CMD ["python", "core/parameter_server.py", "--workers", "2", "--mode", "sync"]
